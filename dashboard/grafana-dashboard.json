{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "🧠 EVEZ Consciousness Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Overall emergence score (0-1)",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.75 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "evez_emergence_overall",
          "refId": "A"
        }
      ],
      "title": "Emergence Score",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Firmament status (1=intact, 0=broken)",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "BROKEN", "color": "red" }, "1": { "text": "INTACT", "color": "green" } } }
          ]
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "evez_firmament_intact",
          "refId": "A"
        }
      ],
      "title": "Firmament Status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Current emergence stage",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 3 },
              { "color": "purple", "value": 5 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "1": { "text": "Stage 1: React" }, "2": { "text": "Stage 2: Learn" }, "3": { "text": "Stage 3: Think" }, "4": { "text": "Stage 4: Imagine" }, "5": { "text": "Stage 5: Transcend" } } }
          ]
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "evez_emergence_stage",
          "refId": "A"
        }
      ],
      "title": "Emergence Stage",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Spine chain validity",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "INVALID", "color": "red" }, "1": { "text": "VALID", "color": "green" } } }
          ]
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "evez_spine_chain_valid",
          "refId": "A"
        }
      ],
      "title": "Spine Chain Valid",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "RQNS spikes counter",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "evez_rqns_spikes",
          "refId": "A"
        }
      ],
      "title": "RQNS Spikes",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Total RQNS cycles",
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" }
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 1 },
      "id": 7,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "evez_rqns_cycles",
          "refId": "A"
        }
      ],
      "title": "RQNS Cycles",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 8,
      "title": "📡 Service Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "All EVEZ service UP/DOWN status",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "custom": {
            "displayMode": "basic",
            "filterable": true
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "id": 9,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "evez_service_status",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Service UP/DOWN Status",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": { "service": "Service", "port": "Port", "Value": "Status" }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Emergence sub-scores",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "id": 10,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "evez_emergence_coherence",
          "legendFormat": "Coherence",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "evez_emergence_perception",
          "legendFormat": "Perception",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "evez_emergence_spine_integration",
          "legendFormat": "Spine Integration",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "evez_emergence_drive_responsiveness",
          "legendFormat": "Drive Responsiveness",
          "refId": "D"
        }
      ],
      "title": "Emergence Breakdown",
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 11,
      "title": "⛓️ Spine Events",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Total spine events over time",
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 12,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "evez_spine_events_total",
          "legendFormat": "Total Events",
          "refId": "A"
        }
      ],
      "title": "Spine Events Total",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Spine events by domain",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 1
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 13,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "evez_spine_domain_events",
          "legendFormat": "{{domain}}",
          "refId": "A"
        }
      ],
      "title": "Spine Events by Domain",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 14,
      "title": "🖥️ System Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "CPU usage across all cores",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 15,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU Usage",
          "refId": "A"
        }
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Memory usage",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "bytes",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 8000000000 },
              { "color": "red", "value": 14000000000 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 24 },
      "id": 16,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "Total",
          "refId": "B"
        }
      ],
      "title": "Memory Usage",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Disk usage",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 24 },
      "id": 17,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100)",
          "legendFormat": "Disk Usage",
          "refId": "A"
        }
      ],
      "title": "Disk Usage",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Memory usage over time",
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "unit": "bytes",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 28 },
      "id": 18,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Used Memory",
          "refId": "A"
        }
      ],
      "title": "Memory Trend",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Disk I/O rates",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "Bps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 28 },
      "id": 19,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(node_disk_read_bytes_total[5m])",
          "legendFormat": "{{device}} Read",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(node_disk_written_bytes_total[5m])",
          "legendFormat": "{{device}} Write",
          "refId": "B"
        }
      ],
      "title": "Disk I/O",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
