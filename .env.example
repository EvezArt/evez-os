# ============================================================
# EVEZ-OS Environment Variables — copy to .env and fill values
# ============================================================

# --- WAVE 1: Revenue (Required first) ---
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
PRICE_MCP_49=price_xxx
PRICE_MEMBERSHIP_29=price_xxx
PRICE_CONSULTING_250=price_xxx
EVEZ_SUCCESS_URL=https://evez.app/success
EVEZ_CANCEL_URL=https://evez.app/cancel
EVEZ_FROM_EMAIL=rubikspubes69@gmail.com
SENDGRID_API_KEY=SG.xxx

# --- WAVE 2: Memory + Storefront ---
DATABASE_URL=postgresql://user:pass@host:5432/evez
METAROM_URL=https://metarom.onrender.com

# --- WAVE 3: AI + Autonomy ---
GROQ_API_KEY=gsk_xxx
GROQ_MODEL=llama3-8b-8192

# --- WAVE 3: Agent Config ---
SELF_IMPROVE_INTERVAL=10
ROLLBACK_THRESHOLD=3
SPAWN_THRESHOLD=5
MAX_CHILDREN_PER_AGENT=3
CHILD_TTL_MINUTES=30

# --- WAVE 3: Spawn ---
AGENTNET_URL=https://evez-agentnet.onrender.com

# --- WAVE 4: Social ---
TWITTER_API_KEY=xxx
TWITTER_ACCESS_TOKEN=xxx
TWITTER_BEARER_TOKEN=xxx
VIRAL_THRESHOLD=100

# --- WAVE 4: Notifications ---
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_CHAT_ID=xxx

# --- WAVE 4: Vote Bus ---
CONSENSUS_HIGH=0.66
CONSENSUS_LOW=0.33

# --- Render Deploy Hooks (for CI) ---
RENDER_DEPLOY_HOOK_EVEZ_OS=https://api.render.com/deploy/srv-xxx?key=xxx
RENDER_DEPLOY_HOOK_METAROM=https://api.render.com/deploy/srv-xxx?key=xxx
