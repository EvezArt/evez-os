    xdg-open "${EVEZ_DASHBOARD}" 2>/dev/null
  elif command -v open &>/dev/null; then
    open "${EVEZ_DASHBOARD}" 2>/dev/null
  else
    echo -e "  Open in browser: ${BOLD}${EVEZ_DASHBOARD}${NC}"
