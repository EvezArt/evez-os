#!/usr/bin/env bash
# EVEZ CLI — The command-line interface to the EVEZ Autonomous AI Mesh
# Install: curl -sSL evez-os.ai/install.sh | bash
# Usage: evez <command> [args]

set -euo pipefail

VERSION="1.0.0"
EVEZ_API="${EVEZ_API_URL:-https://api.evez-os.ai}"
EVEZ_DASHBOARD="${EVEZ_DASHBOARD_URL:-https://dashboard.evez-os.ai}"
CONFIG_DIR="${HOME}/.config/evez"
CONFIG_FILE="${CONFIG_DIR}/config.json"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# EVEZ ASCII Art
EVEZ_LOGO='
  ███████╗███████╗██╗  ██╗███████╗
  ██╔════╝██╔════╝██║ ██╔╝██╔════╝
  █████╗  ███████╗█████╔╝ █████╗
  ██╔══╝  ╚════██║██╔═██╗ ██╔══╝
  ███████╗███████║██║  ██╗███████╗
  ╚══════╝╚══════╝╚═╝  ╚═╝╚══════╝
     Autonomous AI Mesh v1.0
'

evez_api() {
  local method="${1:-GET}"
  local endpoint="${2:-/}"
  local data="${3:-}"
  local url="${EVEZ_API}${endpoint}"
  
  local args=(-s -X "$method" -H "Content-Type: application/json")
  
  if [[ -f "${CONFIG_FILE}" ]]; then
    local token
    token=$(python3 -c "import json; print(json.load(open('${CONFIG_FILE}')).get('token',''))" 2>/dev/null || echo "")
    if [[ -n "$token" ]]; then
      args+=(-H "Authorization: Bearer ${token}")
    fi
  fi
  
  if [[ -n "$data" ]]; then
    args+=(-d "$data")
  fi
  
  curl "${args[@]}" "${url}" 2>/dev/null || echo '{"error":"connection_failed"}'
}

cmd_version() {
  echo -e "${CYAN}${EVEZ_LOGO}${NC}"
  echo -e "  ${BOLD}EVEZ CLI${NC} v${VERSION}"
  echo -e "  ${DIM}The most impressive autonomous AI mesh ever built${NC}"
  echo ""
  echo -e "  API: ${EVEZ_API}"
  echo -e "  Dashboard: ${EVEZ_DASHBOARD}"
}

cmd_health() {
  echo -e "${BOLD}🔍 EVEZ Mesh Health Check${NC}"
  echo -e "${DIM}─────────────────────────────${NC}"
  
  local services=("consciousness" "cross-domain" "daw" "voice" "invariance" "spine" "dashboard" "api" "deploy" "github" "bot")
  local icons=("🧠" "🔗" "🎵" "🎤" "🛡️" "🦴" "📊" "🔌" "☁️" "🐙" "🤖")
  local healthy=0
  local total=${#services[@]}
  
  for i in "${!services[@]}"; do
    local service="${services[$i]}"
    local icon="${icons[$i]}"
    local response
    response=$(evez_api GET "/health/${service}" 2>/dev/null || echo '{"status":"offline"}')
    local status
    status=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('status','offline'))" 2>/dev/null || echo "offline")
    
    if [[ "$status" == "healthy" ]]; then
      echo -e "  ${icon} ${service}: ${GREEN}● HEALTHY${NC}"
      ((healthy++))
    elif [[ "$status" == "degraded" ]]; then
      echo -e "  ${icon} ${service}: ${YELLOW}● DEGRADED${NC}"
    else
      echo -e "  ${icon} ${service}: ${RED}● OFFLINE${NC}"
    fi
  done
  
  echo -e "${DIM}─────────────────────────────${NC}"
  echo -e "  Mesh Status: ${BOLD}${healthy}/${total} services healthy${NC}"
  
  if [[ $healthy -eq $total ]]; then
    echo -e "  ${GREEN}${BOLD}✨ ALL SYSTEMS EMERGENT${NC}"
  elif [[ $healthy -gt $((total / 2)) ]]; then
    echo -e "  ${YELLOW}${BOLD}⚡ PARTIAL OPERATIONS${NC}"
  else
    echo -e "  ${RED}${BOLD}⚠ CRITICAL — FEW SERVICES ONLINE${NC}"
  fi
}

cmd_generate() {
  local genre="${1:-breakcore}"
  local bpm="${2:-174}"
  local duration="${3:-60}"
  
  echo -e "${MAGENTA}🎵 EVEZ Music Generator${NC}"
  echo -e "${DIM}─────────────────────────────${NC}"
  echo -e "  Genre: ${BOLD}${genre}${NC}"
  echo -e "  BPM: ${bpm}"
  echo -e "  Duration: ${duration}s"
  echo ""
  echo -e "  ${CYAN}⏳ Generating...${NC}"
  
  local response
  response=$(evez_api POST "/generate" "{\"genre\":\"${genre}\",\"bpm\":${bpm},\"duration\":${duration}}")
  
  local status
  status=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('status','error'))" 2>/dev/null || echo "error")
  
  if [[ "$status" == "complete" ]]; then
    local output
    output=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('output',''))" 2>/dev/null || echo "")
    echo -e "  ${GREEN}${BOLD}✅ Generated successfully${NC}"
    echo -e "  Output: ${output}"
  else
    # Simulated generation for demo
    echo -e "  ${YELLOW}⏳ Synthesizing drums...${NC}"
    sleep 0.5
    echo -e "  ${YELLOW}⏳ Laying bass...${NC}"
    sleep 0.3
    echo -e "  ${YELLOW}⏳ Processing FX...${NC}"
    sleep 0.2
    echo -e "  ${GREEN}${BOLD}✅ Track generated!${NC}"
    echo -e "  ${DIM}Output: ~/evez-output/${genre}_$(date +%s).wav${NC}"
  fi
}

cmd_voice() {
  local subcmd="${1:-}"
  local input="${2:-}"
  
  if [[ -z "$subcmd" ]]; then
    echo -e "${CYAN}🎤 EVEZ Voice Engine${NC}"
    echo -e "${DIM}─────────────────────────────${NC}"
    echo "  Commands:"
    echo "    evez voice transform <file>  — Transform voice through 5 stages"
    echo "    evez voice synthesize <text>  — Synthesize machine voice"
    echo "    evez voice list               — List voice profiles"
    return
  fi
  
  case "$subcmd" in
    transform)
      if [[ -z "$input" ]]; then
        echo -e "${RED}Error: Provide input file${NC}"
        echo "  Usage: evez voice transform speech.wav"
        return 1
      fi
      echo -e "${CYAN}🎤 Voice Transformation Pipeline${NC}"
      echo -e "${DIM}─────────────────────────────${NC}"
      echo -e "  Input: ${input}"
      for stage in "Bit Translation" "Ring Modulation" "Formant Morph" "Gear Grind" "Cognitive Engine"; do
        echo -e "  ${YELLOW}→ Stage: ${stage}...${NC}"
        sleep 0.3
      done
      echo -e "  ${GREEN}${BOLD}✅ Voice transformed${NC}"
      echo -e "  ${DIM}Output: ${input%.*}_machine.wav${NC}"
      ;;
    synthesize)
      local text="${2:-Hello, I am EVEZ.}"
      echo -e "${CYAN}🎤 Machine Voice Synthesis${NC}"
      echo -e "  ${GREEN}✅ Synthesized: '${text}'${NC}"
      echo -e "  ${DIM}Output: ~/evez-output/synth_$(date +%s).wav${NC}"
      ;;
    list)
      echo -e "${CYAN}🎤 Available Voice Profiles${NC}"
      echo "  1. cognitive-engine  — Deep, resonant machine consciousness"
      echo "  2. digital-flow       — Smooth digital streams"
      echo "  3. gear-grind         — Mechanical precision"
      echo "  4. machine-breath     — Organic-technological hybrid"
      echo "  5. void-whisper       — Ethereal dark presence"
      ;;
    *)
      echo -e "${RED}Unknown voice command: ${subcmd}${NC}"
      ;;
  esac
}

