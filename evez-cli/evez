# Main router
case "${1:-help}" in
  health)      cmd_health ;;
  generate)    cmd_generate "${2:-}" "${3:-}" "${4:-}" ;;
  voice)       cmd_voice "${2:-}" "${3:-}" ;;
  correlate)   cmd_correlate "${2:-}" "${3:-}" ;;
  dream)       cmd_dream ;;
  dashboard)   cmd_dashboard ;;
  deploy)      cmd_deploy "${2:-gcp}" ;;
  status)      cmd_status ;;
  config)      cmd_config "${2:-}" "${3:-}" ;;
  version|-v)  cmd_version ;;
  help|--help) cmd_help ;;
  *)
    echo -e "${RED}Unknown command: ${1}${NC}"
    echo "Run 'evez help' for usage."
    exit 1
    ;;
esac
