cmd_config() {
  local key="${1:-}"
  local value="${2:-}"
  
  mkdir -p "${CONFIG_DIR}"
  
  if [[ -z "$key" ]]; then
    echo -e "${CYAN}⚙️ EVEZ Configuration${NC}"
    if [[ -f "${CONFIG_FILE}" ]]; then
      cat "${CONFIG_FILE}"
    else
      echo "  No configuration found. Run: evez config set api_key <key>"
    fi
    return
  fi
  
  case "$key" in
    set)
      echo "Setting ${value%%=*}..."
      echo "{\"${value%%=*}\":\"${value#*=}\"}" > "${CONFIG_FILE}"
      echo -e "${GREEN}✅ Configured${NC}"
      ;;
    get)
      if [[ -f "${CONFIG_FILE}" ]]; then
        cat "${CONFIG_FILE}"
      else
        echo "No config"
      fi
      ;;
    *)
      echo "Usage: evez config set <key>=<value>"
      ;;
  esac
}

